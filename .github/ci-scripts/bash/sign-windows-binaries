#!/bin/bash
set -euo pipefail

# ─── Required environment variables ───────────────────────────────────────────
required_vars=(
  S3_BUCKET TAR_FILE SIGNED_TAR_FILE
  INSTANCE_ID AWS_PROFILE AWS_REGION
  AZURE_TENANT_ID AZURE_CLIENT_ID AZURE_CLIENT_SECRET
  SIGNING_ACCOUNT_NAME SIGNING_PROFILE_NAME SIGNING_ENDPOINT
  SIGNADMIN_USER SIGNADMIN_PASSWORD
)

for var in "${required_vars[@]}"; do
  if [[ -z "${!var:-}" ]]; then
    echo "❌ Required environment variable '$var' is not set"
    exit 1
  fi
done

# ─── Generate unique build ID for this job ─────────────────────────────────────
BUILD_ID="signing-$(date +%Y%m%d-%H%M%S)-$$"
BUILD_DIR="C:\\\\build-${BUILD_ID}"
# Single backslash versions for use inside PS string literals
BUILD_DIR_PS="C:\\build-${BUILD_ID}"
SIGNADMIN_PASSWORD_JSON=$(echo "$SIGNADMIN_PASSWORD" | sed 's/\\/\\\\/g; s/"/\\"/g')

# ─── Log job details ───────────────────────────────────────────────────────────
echo "🚀 Starting Windows signing pipeline"
echo "   Instance  : $INSTANCE_ID"
echo "   Build ID  : $BUILD_ID"
echo "   TAR file  : $S3_BUCKET/$TAR_FILE"
echo "   Output    : $S3_BUCKET/$SIGNED_TAR_FILE"

# ─── Build SSM command payload ─────────────────────────────────────────────────
CMD1="New-Item -ItemType Directory -Force -Path '${BUILD_DIR_PS}\\artifacts'; Write-Output 'Build dir ready: ${BUILD_DIR_PS}'"
CMD2="aws s3 cp s3://${S3_BUCKET}/${TAR_FILE} '${BUILD_DIR_PS}\\input.tar' --no-progress"
CMD3="tar -xf '${BUILD_DIR_PS}\\input.tar' -C '${BUILD_DIR_PS}\\artifacts'"
CMD4="\$artifactsDir = '${BUILD_DIR_PS}\\artifacts'; \$signDone = '${BUILD_DIR_PS}\\sign-done.txt'; \$signJob = '${BUILD_DIR_PS}\\sign-job.ps1'; \$exeFiles = Get-ChildItem -Path \$artifactsDir -Filter '*.exe' -Recurse; \$lines = @('\$env:AZURE_TENANT_ID = \"${AZURE_TENANT_ID}\"', '\$env:AZURE_CLIENT_ID = \"${AZURE_CLIENT_ID}\"', '\$env:AZURE_CLIENT_SECRET = \"${AZURE_CLIENT_SECRET}\"', 'Import-Module TrustedSigning'); foreach (\$exe in \$exeFiles) { \$lines += \"Invoke-TrustedSigning -Endpoint '${SIGNING_ENDPOINT}' -CodeSigningAccountName '${SIGNING_ACCOUNT_NAME}' -CertificateProfileName '${SIGNING_PROFILE_NAME}' -TimestampRfc3161 'http://timestamp.acs.microsoft.com' -TimestampDigest SHA256 -FileDigest SHA256 -Files '\$(\$exe.FullName)' | Out-Null\" }; \$lines += '\$exes = Get-ChildItem -Path \"${BUILD_DIR_PS}\\\\artifacts\" -Filter \"*.exe\" -Recurse'; \$lines += 'foreach (\$e in \$exes) { \$sig = Get-AuthenticodeSignature \$e.FullName; Write-Output \"\$(\$e.Name): \$(\$sig.Status)\" }'; \$lines += \"Set-Content '${BUILD_DIR_PS}\\\\sign-done.txt' done\"; \$lines | Out-File '${BUILD_DIR_PS}\\sign-job.ps1' -Encoding utf8; Write-Output \"Sign script created with \$(\$exeFiles.Count) exe files\""
CMD5="schtasks /delete /tn \"CodeSign-${BUILD_ID}\" /f 2>\$null; schtasks /create /tn \"CodeSign-${BUILD_ID}\" /tr \"powershell.exe -NonInteractive -ExecutionPolicy Bypass -File '${BUILD_DIR_PS}\\sign-job.ps1'\" /sc once /st 00:00 /ru \"${SIGNADMIN_USER}\" /rp \"${SIGNADMIN_PASSWORD}\" /rl highest /f; schtasks /run /tn \"CodeSign-${BUILD_ID}\"; \$timeout = 300; \$elapsed = 0; while (!(Test-Path '${BUILD_DIR_PS}\\sign-done.txt') -and \$elapsed -lt \$timeout) { Start-Sleep 10; \$elapsed += 10 }; if (Test-Path '${BUILD_DIR_PS}\\sign-done.txt') { Write-Output 'SIGNING_SUCCESS' } else { Write-Output 'SIGNING_TIMEOUT'; exit 1 }"
CMD6="tar -cf '${BUILD_DIR_PS}\\output.tar' -C '${BUILD_DIR_PS}' artifacts"
CMD7="aws s3 cp '${BUILD_DIR_PS}\\output.tar' s3://${S3_BUCKET}/${SIGNED_TAR_FILE} --no-progress; Write-Output 'UPLOAD_SUCCESS'"
CMD8="if (Test-Path '${BUILD_DIR_PS}\\sign-done.txt') { schtasks /delete /tn \"CodeSign-${BUILD_ID}\" /f 2>\$null; Remove-Item '${BUILD_DIR_PS}' -Recurse -Force -ErrorAction SilentlyContinue; Write-Output 'CLEANUP_SUCCESS' } else { Write-Output 'CLEANUP_SKIPPED: build dir kept for debugging at ${BUILD_DIR_PS}' }"

# Use jq to build valid JSON - handles all special characters including ! in passwords
jq -n \
  --arg instance "$INSTANCE_ID" \
  --arg c1 "$CMD1" \
  --arg c2 "$CMD2" \
  --arg c3 "$CMD3" \
  --arg c4 "$CMD4" \
  --arg c5 "$CMD5" \
  --arg c6 "$CMD6" \
  --arg c7 "$CMD7" \
  --arg c8 "$CMD8" \
  '{
    InstanceIds: [$instance],
    DocumentName: "AWS-RunPowerShellScript",
    Parameters: {
      commands: [$c1, $c2, $c3, $c4, $c5, $c6, $c7, $c8]
    }
  }' > "/tmp/ssm-trigger-${BUILD_ID}.json"

# ─── Send command ──────────────────────────────────────────────────────────────
COMMAND_ID=$(aws ssm send-command \
  --cli-input-json "file:///tmp/ssm-trigger-${BUILD_ID}.json" \
  --profile "$AWS_PROFILE" \
  --region "$AWS_REGION" \
  --query 'Command.CommandId' \
  --output text)

echo "📋 SSM Command ID: $COMMAND_ID"

# ─── Wait for completion ───────────────────────────────────────────────────────
echo "⏳ Waiting for command to complete (timeout: 3min)..."
WAIT_TIMEOUT=180
WAIT_ELAPSED=0

while true; do
  STATUS=$(aws ssm get-command-invocation \
    --command-id "$COMMAND_ID" \
    --instance-id "$INSTANCE_ID" \
    --query 'Status' \
    --output text \
    --profile "$AWS_PROFILE" \
    --region "$AWS_REGION" 2>/dev/null || echo "Pending")

  echo "   Status: $STATUS (${WAIT_ELAPSED}s / ${WAIT_TIMEOUT}s)"

  if [[ "$STATUS" == "Success" || "$STATUS" == "Failed" || "$STATUS" == "TimedOut" || "$STATUS" == "Cancelled" ]]; then
    break
  fi

  if [[ $WAIT_ELAPSED -ge $WAIT_TIMEOUT ]]; then
    echo "❌ Timed out waiting for SSM command after ${WAIT_TIMEOUT}s"
    echo "   Command ID: $COMMAND_ID"
    echo "   Build dir kept for debugging: ${BUILD_DIR_PS}"
    exit 1
  fi

  sleep 15
  WAIT_ELAPSED=$((WAIT_ELAPSED + 15))
done

# ─── Fetch and clean output ────────────────────────────────────────────────────
OUTPUT_FILE="/tmp/ssm-output-${BUILD_ID}.txt"
ERROR_FILE="/tmp/ssm-error-${BUILD_ID}.txt"
TRIGGER_FILE="/tmp/ssm-trigger-${BUILD_ID}.json"

aws ssm get-command-invocation \
  --command-id "$COMMAND_ID" \
  --instance-id "$INSTANCE_ID" \
  --query 'StandardOutputContent' \
  --output text \
  --profile "$AWS_PROFILE" \
  --region "$AWS_REGION" | tr -d '\r' > "$OUTPUT_FILE"

aws ssm get-command-invocation \
  --command-id "$COMMAND_ID" \
  --instance-id "$INSTANCE_ID" \
  --query 'StandardErrorContent' \
  --output text \
  --profile "$AWS_PROFILE" \
  --region "$AWS_REGION" | tr -d '\r' > "$ERROR_FILE"

echo ""
echo "─── Output ───────────────────────────────────"
cat "$OUTPUT_FILE"
echo "─── Errors ───────────────────────────────────"
cat "$ERROR_FILE"
echo "──────────────────────────────────────────────"

# ─── Verify success ────────────────────────────────────────────────────────────
if [[ "$STATUS" != "Success" ]]; then
  echo "❌ SSM command status: $STATUS"
  echo "   Build dir kept for debugging: ${BUILD_DIR_PS}"
  rm -f "$TRIGGER_FILE"
  exit 1
fi

if ! grep -q "SIGNING_SUCCESS" "$OUTPUT_FILE"; then
  echo "❌ Signing did not complete successfully"
  echo "   Build dir kept for debugging: ${BUILD_DIR_PS}"
  rm -f "$TRIGGER_FILE"
  exit 1
fi

if ! grep -q "UPLOAD_SUCCESS" "$OUTPUT_FILE"; then
  echo "❌ Upload did not complete successfully"
  echo "   Build dir kept for debugging: ${BUILD_DIR_PS}"
  rm -f "$TRIGGER_FILE"
  exit 1
fi

# ─── Cleanup local temp files only on success ──────────────────────────────────
rm -f "$TRIGGER_FILE" "$OUTPUT_FILE" "$ERROR_FILE"

echo ""
echo "✅ Signing pipeline completed successfully"
echo "   Build ID        : $BUILD_ID"
echo "   Signed artifact : s3://$S3_BUCKET/$SIGNED_TAR_FILE"
