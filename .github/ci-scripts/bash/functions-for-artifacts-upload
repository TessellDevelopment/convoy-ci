#!/bin/bash

source ./ci-scripts/bash/common


function upload_to_nexus() {
  # Remove in next PR
  local local_abs_path_to_src=${1:-} upload_path_in_nexus=${2:-}
  validate_inputs "1 2" "$@"

  log "Uploading artifact from local path '${local_abs_path_to_src}' to Nexus at '${upload_path_in_nexus}'."
  curl -v -u ${NEXUS_USERNAME}:${NEXUS_PASSWORD} \
    --upload-file ${local_abs_path_to_src} -w "%{http_code}" \
    ${NEXUS_ADDR}/repository/${upload_path_in_nexus}
}

function upload_to_nexus_tessell_artifacts() {
  local local_abs_path_to_src=${1:-} dest_path_without_bucket=${2:-}
  validate_inputs "1 2" "$@"

  local response_with_status_code=$(upload_to_nexus ${local_abs_path_to_src} "${NEXUS_ARTIFACT_BUCKET}/${dest_path_without_bucket}")
  echo ${response_with_status_code}

  local status_code=$(echo "${response_with_status_code}" | tail -n1)
  validate_reponse_code "${status_code}" "201"
}


# resolve_artifact_buckets <artifact_name> [convoy_yaml]
# Returns the full list of destination S3 bucket names for an artifact.
#   - If the artifact's entry in convoy.yaml declares 'artifactBuckets', those
#     exact bucket names are used (e.g. tessell-custom-artifacts, tessell-artifacts).
#   - Otherwise the standard tessell-artifacts-{dev,qa,stage,prod} names are returned.
function resolve_artifact_buckets() {
  local artifact_name="${1:-}" convoy_yaml="${2:-./convoy.yaml}" custom_buckets

  if [[ -n "${artifact_name}" && -f "${convoy_yaml}" ]]; then
    readarray -t custom_buckets < <(
      yq ".generates.artifacts[] | select(.name == \"${artifact_name}\") | .artifactBuckets[]?" \
        "${convoy_yaml}" 2>/dev/null
    )
  fi

  if [[ ${#custom_buckets[@]} -gt 0 ]]; then
    printf '%s\n' "${custom_buckets[@]}"
  else
    # Default: derive bucket names from standard deployment stages
    for stage in dev qa stage prod; do
      echo "tessell-artifacts-${stage}"
    done
  fi
}

function upload_artifact() {
  local local_abs_path_to_src=${1:-} dest_path_without_bucket=${2:-} push_to=${3:-s3} artifact_name=${4:-} bucket_names
  validate_inputs "1 2" "$@"

  ensure_accessability_to_upload_locations
  log "Uploading artifact from local path '${local_abs_path_to_src}' to '${dest_path_without_bucket}'."

  readarray -t bucket_names < <(resolve_artifact_buckets "${artifact_name}")

  ${DEV_BUILD:-false} \
    && bucket_names=( tessell-artifacts-devtest ) \
    || upload_to_nexus_tessell_artifacts ${local_abs_path_to_src} ${dest_path_without_bucket}

  if [[ ${push_to} == convoy-minio ]]; then
    local cp_cmd='mc cp'
    dest_path_prefix=${MC_ALIAS_FOR_CONVOY_MINIO}/
  else
    local cp_cmd='aws s3 cp'
    dest_path_prefix=s3://
  fi

  local dest_path_suffix=$(echo ${dest_path_without_bucket} | sed 's|^s3://tessell-artifacts-devtest/||')

  for bucket_name in "${bucket_names[@]}"; do
    log "Running: '${cp_cmd} ${local_abs_path_to_src} ${dest_path_prefix}${bucket_name}/${dest_path_suffix}'"
    ${cp_cmd} ${local_abs_path_to_src} ${dest_path_prefix}${bucket_name}/${dest_path_suffix}
  done
  # unset AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_SESSION_TOKEN
}


function upload_artifacts_using_src_dest_map() {
  local map=${1:-} artifacts local_abs_path_to_src dest_path_without_bucket push_to
  [[ -n ${map:-} ]] || die "This function must invoked with a path to the src-dest-map file as its one-and-only argument. Currently, no argument has been passed."

  log "Validating src-dest-map for artifacts upload..."
  $(yq 'has("artifacts") and .artifacts | type == "!!seq"' ${map}) || \
    die "The src-dest-map must be a yaml file consisting only one top level key 'artifacts' of type list."

  [[ $(yq '[.artifacts[] | select((has("localAbsPathToSrc") and has("destPathWithoutBucket")) | not)] | length' ${map}) -eq 0 ]] || \
    die <(cat <<-EOF
			All src-dest-map entries in the file must have both of the keys: 'localAbsPathToSrc' and 'destPathWithoutBucket'.
			One or more entries in the current file is missing at least one of the required keys.
			EOF
    )

  readarray artifacts < <(yq -o=j -I=0 '.artifacts[]' ${map})

  for artifact in "${artifacts[@]}"; do
    [[ -f $(echo ${artifact} | yq '.localAbsPathToSrc') ]] || \
      die "One or more local paths provided with 'localAbsPathToSrc' does not exist in the local file system."
  done

  log "Validation of src-dest-map for artifacts upload completed. Proceeding with uploads..."

  for artifact in "${artifacts[@]}"; do
    local_abs_path_to_src=$(echo ${artifact} | yq '.localAbsPathToSrc')
    dest_path_without_bucket=$(echo ${artifact} | yq '.destPathWithoutBucket')
    push_to=$(echo ${artifact} | yq '.pushTo')
    artifact_name=$(echo ${artifact} | yq '.artifactName // ""')

    upload_artifact ${local_abs_path_to_src} ${dest_path_without_bucket} ${push_to} ${artifact_name}
  done
}
