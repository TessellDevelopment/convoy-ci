#!/bin/bash
set -euo pipefail

readonly REQUIRED_ENV_VARS=(
  S3_ARTIFACT_KEY
  S3_SIGNED_ARTIFACT_KEY
  ARTIFACT_FILENAME
  EXTRACT_CMD
  ARCHIVE_CMD
  WINDOWS_SIGNING_S3_BUCKET
  WINDOWS_SIGNING_INSTANCE_ID
  WINDOWS_SIGNING_AWS_REGION
  WINDOWS_SIGNING_AZURE_TENANT_ID
  WINDOWS_SIGNING_AZURE_CLIENT_ID
  WINDOWS_SIGNING_AZURE_CLIENT_SECRET
  WINDOWS_SIGNING_ACCOUNT_NAME
  WINDOWS_SIGNING_PROFILE_NAME
  WINDOWS_SIGNING_ENDPOINT
  WINDOWS_SIGNING_ADMIN_USER
  WINDOWS_SIGNING_ADMIN_PASSWORD
)

readonly build_dir_ps="C:\\build-${BUILD_ID}"
readonly trigger_file="/tmp/ssm-trigger-${BUILD_ID}.json"

function validate_environment() {
  local missing_vars=()

  for var in "${REQUIRED_ENV_VARS[@]}"; do
    if [[ -z "${!var:-}" ]]; then
      missing_vars+=("$var")
    fi
  done

  if [[ ${#missing_vars[@]} -gt 0 ]]; then
    echo "❌ Missing required environment variables:"
    printf '   - %s\n' "${missing_vars[@]}"
    exit 1
  fi
}

function build_cmd_create_directory() {
  echo "New-Item -ItemType Directory -Force -Path '${build_dir_ps}\\artifacts'; Write-Output 'Build dir ready: ${build_dir_ps}'"
}

function build_cmd_download_from_s3() {
  echo "aws s3 cp s3://${WINDOWS_SIGNING_S3_BUCKET}/${S3_ARTIFACT_KEY} '${build_dir_ps}\\${ARTIFACT_FILENAME}' --no-progress"
}

function build_cmd_extract_artifact() {
  local extract_cmd="${EXTRACT_CMD//INPUT_FILE/${build_dir_ps}\\\\${ARTIFACT_FILENAME}}"
  extract_cmd="${extract_cmd//OUTPUT_DIR/${build_dir_ps}\\\\artifacts}"
  echo "${extract_cmd}"
}

function build_cmd_create_signing_script() {
  cat <<EOF
\$artifactsDir = '${build_dir_ps}\\artifacts'; \$signDone = '${build_dir_ps}\\sign-done.txt'; \$signJob = '${build_dir_ps}\\sign-job.ps1'; \$exeFiles = Get-ChildItem -Path \$artifactsDir -Filter '*.exe' -Recurse; \$lines = @('\$ErrorActionPreference = "Stop"', '\$env:AZURE_TENANT_ID = "${WINDOWS_SIGNING_AZURE_TENANT_ID}"', '\$env:AZURE_CLIENT_ID = "${WINDOWS_SIGNING_AZURE_CLIENT_ID}"', '\$env:AZURE_CLIENT_SECRET = "${WINDOWS_SIGNING_AZURE_CLIENT_SECRET}"', 'Import-Module TrustedSigning'); foreach (\$exe in \$exeFiles) { \$lines += "Invoke-TrustedSigning -Endpoint '${WINDOWS_SIGNING_ENDPOINT}' -CodeSigningAccountName '${WINDOWS_SIGNING_ACCOUNT_NAME}' -CertificateProfileName '${WINDOWS_SIGNING_PROFILE_NAME}' -TimestampRfc3161 'http://timestamp.acs.microsoft.com' -TimestampDigest SHA256 -FileDigest SHA256 -Files '\$(\$exe.FullName)' | Out-Null" }; \$lines += '\$exes = Get-ChildItem -Path "${build_dir_ps}\\\\artifacts" -Filter "*.exe" -Recurse'; \$lines += 'foreach (\$e in \$exes) { \$sig = Get-AuthenticodeSignature \$e.FullName; if (\$sig.Status -ne "Valid") { Write-Error "Signature verification failed for \$(\$e.Name): \$(\$sig.Status)"; exit 1 } else { Write-Output "\$(\$e.Name): \$(\$sig.Status)" } }'; \$lines += "Set-Content '${build_dir_ps}\\\\sign-done.txt' done"; \$lines | Out-File '${build_dir_ps}\\sign-job.ps1' -Encoding utf8; Write-Output "Sign script created with \$(\$exeFiles.Count) exe files"
EOF
}

function build_cmd_execute_signing() {
  cat <<EOF
schtasks /delete /tn "CodeSign-${BUILD_ID}" /f 2>\$null; schtasks /create /tn "CodeSign-${BUILD_ID}" /tr "powershell.exe -NonInteractive -ExecutionPolicy Bypass -File '${build_dir_ps}\\sign-job.ps1'" /sc once /st 00:00 /ru "${WINDOWS_SIGNING_ADMIN_USER}" /rp "${WINDOWS_SIGNING_ADMIN_PASSWORD}" /rl highest /f; schtasks /run /tn "CodeSign-${BUILD_ID}"; \$timeout = 300; \$elapsed = 0; while (!(Test-Path '${build_dir_ps}\\sign-done.txt') -and \$elapsed -lt \$timeout) { Start-Sleep 10; \$elapsed += 10 }; if (Test-Path '${build_dir_ps}\\sign-done.txt') { Write-Output 'SIGNING_SUCCESS' } else { Write-Output 'SIGNING_TIMEOUT'; exit 1 }
EOF
}

function build_cmd_create_output_archive() {
  local archive_cmd="${ARCHIVE_CMD//OUTPUT_FILE/${build_dir_ps}\\\\${ARTIFACT_FILENAME}}"
  archive_cmd="${archive_cmd//INPUT_DIR/${build_dir_ps}\\\\artifacts}"
  echo "${archive_cmd}"
}

function build_cmd_upload_to_s3() {
  echo "aws s3 cp '${build_dir_ps}\\${ARTIFACT_FILENAME}' s3://${WINDOWS_SIGNING_S3_BUCKET}/${S3_SIGNED_ARTIFACT_KEY} --no-progress; Write-Output 'UPLOAD_SUCCESS'"
}

function build_cmd_cleanup() {
  echo "if (Test-Path '${build_dir_ps}\\sign-done.txt') { schtasks /delete /tn \"CodeSign-${BUILD_ID}\" /f 2>\$null; Remove-Item '${build_dir_ps}' -Recurse -Force -ErrorAction SilentlyContinue; Write-Output 'CLEANUP_SUCCESS' } else { Write-Output 'CLEANUP_SKIPPED: build dir kept for debugging at ${build_dir_ps}' }"
}

function create_ssm_payload() {
  local cmd1 cmd2 cmd3 cmd4 cmd5 cmd6 cmd7 cmd8

  cmd1=$(build_cmd_create_directory)
  cmd2=$(build_cmd_download_from_s3)
  cmd3=$(build_cmd_extract_artifact)
  cmd4=$(build_cmd_create_signing_script)
  cmd5=$(build_cmd_execute_signing)
  cmd6=$(build_cmd_create_output_archive)
  cmd7=$(build_cmd_upload_to_s3)
  cmd8=$(build_cmd_cleanup)

  jq -n \
    --arg instance ${WINDOWS_SIGNING_INSTANCE_ID} \
    --arg c1 ${cmd1} \
    --arg c2 ${cmd2} \
    --arg c3 ${cmd3} \
    --arg c4 ${cmd4} \
    --arg c5 ${cmd5} \
    --arg c6 ${cmd6} \
    --arg c7 ${cmd7} \
    --arg c8 ${cmd8} \
    '{
      InstanceIds: [$instance],
      DocumentName: "AWS-RunPowerShellScript",
      Parameters: {
        commands: [$c1, $c2, $c3, $c4, $c5, $c6, $c7, $c8]
      }
    }' > ${trigger_file}
}

function execute_ssm_command() {
  local send_response
  local command_id
  local invocation_response
  local status
  local status_details

  echo "🚀 Starting Windows signing pipeline"

  send_response=$(aws ssm send-command \
    --cli-input-json "file://${trigger_file}" \
    --region ${WINDOWS_SIGNING_AWS_REGION} \
    --timeout-seconds 900 \
    --cli-read-timeout 900 \
    --output json)

  command_id=$(echo ${send_response} | jq -r '.Command.CommandId')
  echo "📋 Command ID: ${command_id}"
  echo "⏳ Waiting for command to complete (timeout: 15min)..."

  aws ssm wait command-executed \
    --command-id ${command_id} \
    --instance-id ${WINDOWS_SIGNING_INSTANCE_ID} \
    --region ${WINDOWS_SIGNING_AWS_REGION}

  invocation_response=$(aws ssm get-command-invocation \
    --command-id ${command_id} \
    --instance-id ${WINDOWS_SIGNING_INSTANCE_ID} \
    --region ${WINDOWS_SIGNING_AWS_REGION} \
    --output json)

  status=$(echo ${invocation_response} | jq -r '.Status')
  status_details=$(echo ${invocation_response} | jq -r '.StatusDetails')

  echo "─── Command Status ───────────────────────────"
  echo "Status: ${status}"
  echo "Details: ${status_details}"
  echo "─── Output ───────────────────────────────────"
  echo ${invocation_response} | jq -r '.StandardOutputContent' | tr -d '\r'
  echo "─── Errors ───────────────────────────────────"
  echo ${invocation_response} | jq -r '.StandardErrorContent' | tr -d '\r'
  echo "──────────────────────────────────────────────"

  if [[ "${status}" != "Success" ]]; then
    echo "❌ Command execution failed with status: ${status}"
    echo "   Build dir kept for debugging: ${build_dir_ps}"
    rm -f ${trigger_file}
    exit 1
  fi
  rm -f ${trigger_file}
  echo "✅ Signing pipeline completed successfully for ${S3_ARTIFACT_KEY}"
}

# Main execution
validate_environment
create_ssm_payload
execute_ssm_command
