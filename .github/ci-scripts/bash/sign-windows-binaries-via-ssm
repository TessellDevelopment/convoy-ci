#!/bin/bash
set -euo pipefail

required_vars=(
  TAR_FILE
  WINDOWS_SIGNING_S3_BUCKET
  WINDOWS_SIGNING_INSTANCE_ID
  WINDOWS_SIGNING_AWS_REGION
  WINDOWS_SIGNING_AZURE_TENANT_ID
  WINDOWS_SIGNING_AZURE_CLIENT_ID
  WINDOWS_SIGNING_AZURE_CLIENT_SECRET
  WINDOWS_SIGNING_ACCOUNT_NAME
  WINDOWS_SIGNING_PROFILE_NAME
  WINDOWS_SIGNING_ENDPOINT
  WINDOWS_SIGNING_ADMIN_USER
  WINDOWS_SIGNING_ADMIN_PASSWORD
)

for var in "${required_vars[@]}"; do
  if [[ -z "${!var:-}" ]]; then
    echo "❌ Required environment variable '${var}' is not set"
    exit 1
  fi
done

BUILD_DIR_PS="C:\\build-${BUILD_ID}"

echo "🚀 Starting Windows signing pipeline"

# ─── Build SSM command payload ─────────────────────────────────────────────────
CMD1="New-Item -ItemType Directory -Force -Path '${BUILD_DIR_PS}\\artifacts'; Write-Output 'Build dir ready: ${BUILD_DIR_PS}'"
CMD2="aws s3 mv s3://${WINDOWS_SIGNING_S3_BUCKET}/${TAR_FILE}-${BUILD_ID} '${BUILD_DIR_PS}\\input.tar' --no-progress"
CMD3="tar -xf '${BUILD_DIR_PS}\\input.tar' -C '${BUILD_DIR_PS}\\artifacts'"
CMD4="\$artifactsDir = '${BUILD_DIR_PS}\\artifacts'; \$signDone = '${BUILD_DIR_PS}\\sign-done.txt'; \$signJob = '${BUILD_DIR_PS}\\sign-job.ps1'; \$exeFiles = Get-ChildItem -Path \$artifactsDir -Filter '*.exe' -Recurse; \$lines = @('\$env:AZURE_TENANT_ID = \"${WINDOWS_SIGNING_AZURE_TENANT_ID}\"', '\$env:AZURE_CLIENT_ID = \"${WINDOWS_SIGNING_AZURE_CLIENT_ID}\"', '\$env:AZURE_CLIENT_SECRET = \"${WINDOWS_SIGNING_AZURE_CLIENT_SECRET}\"', 'Import-Module TrustedSigning'); foreach (\$exe in \$exeFiles) { \$lines += \"Invoke-TrustedSigning -Endpoint '${WINDOWS_SIGNING_ENDPOINT}' -CodeSigningAccountName '${WINDOWS_SIGNING_ACCOUNT_NAME}' -CertificateProfileName '${WINDOWS_SIGNING_PROFILE_NAME}' -TimestampRfc3161 'http://timestamp.acs.microsoft.com' -TimestampDigest SHA256 -FileDigest SHA256 -Files '\$(\$exe.FullName)' | Out-Null\" }; \$lines += '\$exes = Get-ChildItem -Path \"${BUILD_DIR_PS}\\\\artifacts\" -Filter \"*.exe\" -Recurse'; \$lines += 'foreach (\$e in \$exes) { \$sig = Get-AuthenticodeSignature \$e.FullName; Write-Output \"\$(\$e.Name): \$(\$sig.Status)\" }'; \$lines += \"Set-Content '${BUILD_DIR_PS}\\\\sign-done.txt' done\"; \$lines | Out-File '${BUILD_DIR_PS}\\sign-job.ps1' -Encoding utf8; Write-Output \"Sign script created with \$(\$exeFiles.Count) exe files\""
CMD5="schtasks /delete /tn \"CodeSign-${BUILD_ID}\" /f 2>\$null; schtasks /create /tn \"CodeSign-${BUILD_ID}\" /tr \"powershell.exe -NonInteractive -ExecutionPolicy Bypass -File '${BUILD_DIR_PS}\\sign-job.ps1'\" /sc once /st 00:00 /ru \"${WINDOWS_SIGNING_ADMIN_USER}\" /rp \"${WINDOWS_SIGNING_ADMIN_PASSWORD}\" /rl highest /f; schtasks /run /tn \"CodeSign-${BUILD_ID}\"; \$timeout = 300; \$elapsed = 0; while (!(Test-Path '${BUILD_DIR_PS}\\sign-done.txt') -and \$elapsed -lt \$timeout) { Start-Sleep 10; \$elapsed += 10 }; if (Test-Path '${BUILD_DIR_PS}\\sign-done.txt') { Write-Output 'SIGNING_SUCCESS' } else { Write-Output 'SIGNING_TIMEOUT'; exit 1 }"
CMD6="tar -cf '${BUILD_DIR_PS}\\output.tar' -C '${BUILD_DIR_PS}' artifacts"
CMD7="aws s3 mv '${BUILD_DIR_PS}\\output.tar' s3://${WINDOWS_SIGNING_S3_BUCKET}/${SIGNED_TAR_FILE}-${BUILD_ID} --no-progress; Write-Output 'UPLOAD_SUCCESS'"
CMD8="if (Test-Path '${BUILD_DIR_PS}\\sign-done.txt') { schtasks /delete /tn \"CodeSign-${BUILD_ID}\" /f 2>\$null; Remove-Item '${BUILD_DIR_PS}' -Recurse -Force -ErrorAction SilentlyContinue; Write-Output 'CLEANUP_SUCCESS' } else { Write-Output 'CLEANUP_SKIPPED: build dir kept for debugging at ${BUILD_DIR_PS}' }"

jq -n \
  --arg instance "$WINDOWS_SIGNING_INSTANCE_ID" \
  --arg c1 "$CMD1" \
  --arg c2 "$CMD2" \
  --arg c3 "$CMD3" \
  --arg c4 "$CMD4" \
  --arg c5 "$CMD5" \
  --arg c6 "$CMD6" \
  --arg c7 "$CMD7" \
  --arg c8 "$CMD8" \
  '{
    InstanceIds: [$instance],
    DocumentName: "AWS-RunPowerShellScript",
    Parameters: {
      commands: [$c1, $c2, $c3, $c4, $c5, $c6, $c7, $c8]
    }
  }' > "/tmp/ssm-trigger-${BUILD_ID}.json"

# ─── Send command ──────────────────────────────────────────────────────────────
COMMAND_ID=$(aws ssm send-command \
  --cli-input-json "file:///tmp/ssm-trigger-${BUILD_ID}.json" \
  --region "$WINDOWS_SIGNING_AWS_REGION"  \
  --query 'Command.CommandId' --timeout-seconds 180 \
  --output text)

echo "⏳ Waiting for command to complete (timeout: 3min)..."
aws ssm wait command-executed \
  --command-id "$COMMAND_ID" \
  --instance-id "$WINDOWS_SIGNING_INSTANCE_ID" \
  --region "$WINDOWS_SIGNING_AWS_REGION"

OUTPUT_FILE="/tmp/ssm-output-${BUILD_ID}.txt"
ERROR_FILE="/tmp/ssm-error-${BUILD_ID}.txt"
TRIGGER_FILE="/tmp/ssm-trigger-${BUILD_ID}.json"

aws ssm get-command-invocation \
  --command-id "$COMMAND_ID" \
  --instance-id "$WINDOWS_SIGNING_INSTANCE_ID" \
  --query 'StandardOutputContent' \
  --output text \
  --region "$WINDOWS_SIGNING_AWS_REGION" | tr -d '\r' > "$OUTPUT_FILE"

aws ssm get-command-invocation \
  --command-id "$COMMAND_ID" \
  --instance-id "$WINDOWS_SIGNING_INSTANCE_ID" \
  --query 'StandardErrorContent' \
  --output text \
  --region "$WINDOWS_SIGNING_AWS_REGION" | tr -d '\r' > "$ERROR_FILE"

echo ""
echo "─── Output ───────────────────────────────────"
cat "$OUTPUT_FILE"
echo "─── Errors ───────────────────────────────────"
cat "$ERROR_FILE"
echo "──────────────────────────────────────────────"

if ! grep -q "SIGNING_SUCCESS" "$OUTPUT_FILE"; then
  echo "❌ Signing did not complete successfully"
  echo "   Build dir kept for debugging: ${BUILD_DIR_PS}"
  rm -f "$TRIGGER_FILE"
  exit 1
fi

if ! grep -q "UPLOAD_SUCCESS" "$OUTPUT_FILE"; then
  echo "❌ Upload did not complete successfully"
  echo "   Build dir kept for debugging: ${BUILD_DIR_PS}"
  rm -f "$TRIGGER_FILE"
  exit 1
fi

rm -f "$TRIGGER_FILE" "$OUTPUT_FILE" "$ERROR_FILE"
echo "✅ Signing pipeline completed successfully for ${TAR_FILE}"

